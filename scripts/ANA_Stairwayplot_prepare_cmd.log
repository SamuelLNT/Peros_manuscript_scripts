######
#log on 4 Nov to run easySFS on 300 windows with -M2 -V mnps,indels,others filtering
######

#setting path for easySFS
export PATH="/projappl/project_number/SFS_kit/easySFS_env/bin/:$PATH"
export PATH="/projappl/project_number/SFS_kit/easySFS/:$PATH"

#Starting Sinteractive Job
sinteractive -A project_number -c 5 -j SFS -m 30G -t 5:00:00


####
## Data generatoion
####

vcftools --gzvcf Eros_icarus_REF_fullsites_M2Invariant_70missing.vcf.gz --thin 300 --recode --stdout | gzip -c > Eros_icarus_REF_fullsites_M2Invariant_70missing_300window.vcf.gz && bcftools stats Eros_icarus_REF_fullsites_M2Invariant_70missing_50window.vcf.gz > 300window.stats.txt


##### Data information

less 300window.stats.txt


